# ============================================================
# Money Multiply — admin backend (Supabase)
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real secrets.
# ============================================================

# Supabase project (Project Settings → API)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SERVICE ROLE key — server-only, bypasses RLS. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret used to sign admin session cookies. Use a long random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
ADMIN_SESSION_SECRET=replace-with-a-long-random-string

# Passcode seeded into the DB on first login (you can change it afterwards
# from the console). Defaults to MM@2026 if omitted.
ADMIN_INITIAL_PASSCODE=MM@2026
